# Copy to .env and fill in real values. Used by docker-compose and local dev.

# --- LLM ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
LLM_DEFAULT_MODEL=gemini-2.5-flash

# --- Backend ---
# For Docker Compose this is overridden to point at the `db` service.
# For local (non-Docker) dev, point at your local Postgres.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/managed_care_platform
JWT_SECRET=change-me-to-a-32-byte-hex-string
CORS_ORIGINS=["http://localhost:3000"]
